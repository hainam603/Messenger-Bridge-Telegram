# Required: Telegram bot token from @BotFather.
TG_TOKEN=1234567890:replace_me

# Required: Telegram forum supergroup id, for example -1001234567890.
# The bot needs admin rights to manage topics and send messages.
TG_GROUP_ID=-1001234567890

# Required: Facebook cookie for the Messenger account.
# Set the cookie directly or point to a local text file.
FACEBOOK_COOKIE=c_user=...; xs=...; fr=...; datr=...;
# FACEBOOK_COOKIE_FILE=./facebook-cookie.txt

# Persistent storage for topic/message mapping.
DATA_DIR=./data

# Optional in this workspace: the code auto-detects ../fbchat-v2/src.
# Set this manually if you move the folders elsewhere.
# FBCHAT_V2_SRC_PATH=../fbchat-v2/src

# Optional in this workspace: the code auto-detects ../fbchat-v2/build/fbchat-bridge-e2ee.exe.
# Set this manually if you use another binary path.
# FBCHAT_E2EE_BIN=../fbchat-v2/build/fbchat-bridge-e2ee.exe

FBCHAT_ENABLE_E2EE=1
FBCHAT_E2EE_MEMORY_ONLY=1
FBCHAT_E2EE_LOG_LEVEL=none
# FBCHAT_E2EE_DEVICE_PATH=./data/e2ee-device.json

IGNORE_SELF_MESSAGES=1
MESSAGE_CACHE_LIMIT=3000